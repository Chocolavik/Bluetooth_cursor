<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- App title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#E0E0E0"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Laptop → Tablet Bluetooth Bridge"
            android:textSize="14sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="32dp" />

        <!-- Status card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="Checking setup…"
                android:textColor="#B0BEC5"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.4"
                android:fontFamily="monospace" />

        </androidx.cardview.widget.CardView>

        <!-- Step 1: Overlay permission -->
        <Button
            android:id="@+id/btn_overlay_permission"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="1. Grant Overlay Permission"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginBottom="12dp" />

        <!-- Step 2: Accessibility -->
        <Button
            android:id="@+id/btn_accessibility"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="2. Open Accessibility Settings"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2C2C2C"
            android:layout_marginBottom="24dp" />

        <!-- Start server -->
        <Button
            android:id="@+id/btn_start_server"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="▶  START SERVER"
            android:backgroundTint="#00897B"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:enabled="false"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="After starting, move the laptop cursor to the right edge\nto transfer control. Press Meta key to return."
            android:textSize="12sp"
            android:textColor="#616161"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5" />

    </LinearLayout>
</ScrollView>
